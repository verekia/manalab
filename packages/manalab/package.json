    "dev": "tsup --watch"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.183.2",
    "vite": "^8.0.1",
    "@vitejs/plugin-react": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "tsup": "^8.5.0",
    "typescript": "~5.9.3"
